#include <iostream>
#include <string>
#include <fstream>

using namespace std;

// INTEGRANTE 1: TEMA - GESTOR DE PROCESOS (LISTA ENLAZADA COMPLETADA)
struct Proceso {
    int id;
    string nombre;
    int prioridad;
    Proceso* siguiente;
};

class GestorProcesos {
public:
    Proceso* cabeza = NULL;

    void insertar(int _id, string _nom, int _prio) {
        Proceso* nuevo = new Proceso{_id, _nom, _prio, cabeza};
        cabeza = nuevo;
    }

    Proceso* buscar(int _id) {
        Proceso* temp = cabeza;
        while (temp != NULL) {
            if (temp->id == _id) return temp;
            temp = temp->siguiente;
        }
        return NULL;
    }

    void modificarPrioridad(int _id, int nuevaPrio) {
        Proceso* p = buscar(_id);
        if (p != NULL) p->prioridad = nuevaPrio;
    }

    void eliminar(int _id) {
        Proceso* actual = cabeza;
        Proceso* anterior = NULL;
        while (actual != NULL && actual->id != _id) {
            anterior = actual;
            actual = actual->siguiente;
        }
        if (actual == NULL) return;
        if (anterior == NULL) cabeza = cabeza->siguiente;
        else anterior->siguiente = actual->siguiente;
        delete actual;
    }
};

// INTEGRANTE 2: TEMA - PLANIFICADOR DE CPU (COLA DE PRIORIDAD COMPLETADA)
struct NodoCola {
    int id;
    int prioridad;
    NodoCola* siguiente;
};

class PlanificadorCPU {
public:
    NodoCola* frente = NULL;

    void encolar(int _id, int _prio) {
        NodoCola* nuevo = new NodoCola{_id, _prio, NULL};
        if (frente == NULL || _prio > frente->prioridad) {
            nuevo->siguiente = frente;
            frente = nuevo;
        } else {
            NodoCola* temp = frente;
            while (temp->siguiente != NULL && temp->siguiente->prioridad >= _prio) {
                temp = temp->siguiente;
            }
            nuevo->siguiente = temp->siguiente;
            temp->siguiente = nuevo;
        }
    }

    void desencolar() {
        if (frente == NULL) return;
        NodoCola* temp = frente;
        cout << "CPU Ejecutando ID: " << temp->id << endl;
        frente = frente->siguiente;
        delete temp;
    }

    void mostrar() {
        NodoCola* temp = frente;
        while (temp != NULL) {
            cout << "[ID: " << temp->id << " Prio: " << temp->prioridad << "] -> ";
            temp = temp->siguiente;
        }
        cout << "NULL" << endl;
    }
};

// INTEGRANTE 3: TEMA - GESTOR DE MEMORIA Y PERSISTENCIA (PILA Y ARCHIVOS)
struct Bloque {
    int idMemoria;
    Bloque* siguiente;
};

class GestorMemoria {
public:
    Bloque* tope = NULL;

    void push(int _id) {
        Bloque* nuevo = new Bloque{_id, tope};
        tope = nuevo;
    }

    void pop() {
        if (tope == NULL) return;
        Bloque* temp = tope;
        tope = tope->siguiente;
        delete temp;
    }

    void verificar() {
        Bloque* temp = tope;
        while (temp != NULL) {
            cout << "| ID: " << temp->idMemoria << " |" << endl;
            temp = temp->siguiente;
        }
    }

    void guardar() {
        ofstream archivo("memoria.txt");
        Bloque* temp = tope;
        while (temp != NULL) {
            archivo << temp->idMemoria << endl;
            temp = temp->siguiente;
        }
        archivo.close();
    }

    void cargar() {
        ifstream archivo("memoria.txt");
        int _id;
        while (archivo >> _id) {
            push(_id);
        }
        archivo.close();
    }
};

// INTEGRANTE 4: TEMA - INTERFAZ DE USUARIO INTEGRAL
int main() {
    GestorProcesos lista;
    PlanificadorCPU cola;
    GestorMemoria pila;
    
    int opcion, id, prio;
    string nom;

    do {
        cout << "\n=== SISTEMA OPERATIVO ===" << endl;
