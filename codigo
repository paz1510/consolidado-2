        cout << "5. Encolar CPU (Cola)\n6. Ejecutar en CPU (Cola)\n7. Mostrar Cola CPU" << endl;
        cout << "8. Asignar Memoria (Pila)\n9. Liberar Memoria (Pila)\n10. Mostrar Memoria\n11. Guardar Todo\n12. Cargar Todo\n0. Salir" << endl;
        cout << "Opcion: ";
        cin >> opcion;

        switch(opcion) {
            case 1:
                cout << "ID, Nombre, Prio: "; cin >> id >> nom >> prio;
                lista.insertar(id, nom, prio);
