            case 5:
                cout << "ID y Prio para CPU: "; cin >> id >> prio;
                cola.encolar(id, prio);
                break;
            case 6:
                cola.desencolar();
                break;
            case 7:
                cola.mostrar();
                break;
            case 8:
                cout << "ID Bloque Memoria: "; cin >> id;
                pila.push(id);
                break;
            case 9:
                pila.pop();
                break;
            case 10:
                pila.verificar();
                break;
            case 11:
                pila.guardar();
                cout << "Datos guardados." << endl;
                break;
            case 12:
                pila.cargar();
                cout << "Datos cargados." << endl;
                break;
        }
    } while(opcion != 0);

    return 0;
}
